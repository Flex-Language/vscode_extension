{
  "name": "flex-language",
  "displayName": "Flex Language Support",
  "description": "Language support for the Flex programming language - a multi-syntax language for beginners and advanced developers",
  "version": "1.1.0",
  "publisher": "mikawi",
  "author": {
    "name": "mikawi"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#C80000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "flex",
    "programming",
    "franco-arabic",
    "multi-syntax",
    "beginners"
  ],
  "activationEvents": [
    "onLanguage:flex"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "flex",
        "aliases": [
          "Flex",
          "flex"
        ],
        "extensions": [
          ".lx",
          ".fx",
          ".flex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flex",
        "scopeName": "source.flex",
        "path": "./syntaxes/flex.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flex",
        "path": "./snippets/flex.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "echo Compilation not needed - grammar only extension",
    "watch": "echo Watch not needed - grammar only extension",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^14.18.63",
    "@types/vscode": "^1.96.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mikawi/flex-language"
  },
  "bugs": {
    "url": "https://github.com/mikawi/flex-language/issues"
  },
  "homepage": "https://github.com/mikawi/flex-language#readme"
}
